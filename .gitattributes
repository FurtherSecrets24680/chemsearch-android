* text=auto

# Keep Gradle and source files stable across macOS, Linux, and Windows.
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.properties text eol=lf
local.properties.example text eol=lf
keystore.properties.example text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Wrapper scripts need platform-specific endings.
gradlew text eol=lf
*.bat text eol=crlf

# Never normalize binary assets or release artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.jar binary
*.apk binary
*.aab binary
*.dm binary
*.jks binary
*.keystore binary
*.p12 binary
*.pfx binary
